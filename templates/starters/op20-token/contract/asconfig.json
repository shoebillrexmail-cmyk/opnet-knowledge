{
  "targets": {
    "debug": {
      "outFile": "build/MyToken-debug.wasm",
      "textFile": "build/MyToken-debug.wat",
      "sourceMap": true,
      "debug": true
    },
    "release": {
      "outFile": "build/MyToken.wasm",
      "textFile": "build/MyToken.wat",
      "sourceMap": true,
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": false,
      "noAssert": false
    }
  },
  "options": {
    "bindings": "esm",
    "exportRuntime": true,
    "lib": ["node_modules/@btc-vision/btc-runtime/runtime"]
  }
}
